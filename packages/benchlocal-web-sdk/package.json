{
  "name": "@benchlocal/web-sdk",
  "version": "0.3.0",
  "description": "Browser SDK for interactive BenchLocal Web Bench Packs.",
  "author": "stevibe",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevibe/BenchLocal.git",
    "directory": "packages/benchlocal-web-sdk"
  },
  "homepage": "https://github.com/stevibe/BenchLocal",
  "bugs": {
    "url": "https://github.com/stevibe/BenchLocal/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "benchlocal",
    "benchpack",
    "web",
    "llm",
    "benchmark",
    "sdk"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@benchlocal/core": "0.3.0"
  }
}
